<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title id="pageTitle"> HD! - Колония (2026) смотреть онлайн</title>

<link rel="icon" href="/Pic/ava.png" type="image/png">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
    body { background: #050505; color: #e5e7eb; font-family: 'Inter', sans-serif; }
</style>

</head>

<body class="antialiased">

<header style="text-align:center; padding:20px; background:#000;">
    <h1 id="filmTitle">Колония (2026)</h1>
</header>

<div style="text-align:center; margin-top:50px;">
    <a href="https://n5bc.shop/3/rd.php?url=/t/6OX8YoJsH">СМОТРЕТЬ</a>
</div>

<script>

// ====== ТВОЙ ФИКС ======

let slug = window.location.pathname;

// убираем /
slug = slug.replace(/\//g, '');

let filmName = "Колония (2026)";

if(slug.length > 0){
    filmName = slug
        .replace(/-/g,' ')
        .replace(/\b\w/g, l => l.toUpperCase());
}

// меняем TITLE
document.getElementById("pageTitle").innerText =
"HD! - " + filmName + " смотреть онлайн";

// меняем H1
document.getElementById("filmTitle").innerText =
filmName;

</script>

</body>
</html>
